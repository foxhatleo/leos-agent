{
  "permissions": {
    "defaultMode": "auto"
  },
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "agentPushNotifEnabled": true,
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash",
        "hooks": [ { "type": "command", "command": "python3 \"$HOME/.claude/hooks/bash-guard.py\"", "timeout": 10 } ] }
    ]
  }
}

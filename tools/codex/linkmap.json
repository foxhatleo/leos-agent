{
  "$doc": "Codex delivery map. hooks.json is symlinked whole-file (Codex doesn't rewrite it; doctor asserts it stays a symlink). Skills go to ~/.agents/skills (Codex reads it natively). config.toml is merged, not linked.",
  "toolHome": "~/.codex",
  "links": [
    { "dest": "~/.codex/hooks/bash-guard.py", "src": "core/hooks/bash-guard.py" },
    { "dest": "~/.codex/hooks/format-on-edit.py", "src": "core/hooks/format-on-edit.py" },
    { "dest": "~/.codex/council/bin/council.py", "src": "core/council/bin/council.py" },
    { "dest": "~/.codex/hooks.json", "src": "tools/codex/hooks.json", "note": "whole-file symlink; doctor asserts still-a-symlink" },
    { "dest": "~/.agents/skills/council", "src": "core/skills/council", "type": "dir", "note": "Codex reads ~/.agents/skills natively; shared with OpenCode/Cursor" },
    { "dest": "~/.codex/AGENTS.md", "src": "global/AGENTS.md" }
  ],
  "merges": [
    { "dest": "~/.codex/config.toml", "fragment": "tools/codex/config-fragment.toml", "strategy": "merge-toml" }
  ],
  "machineLocal": [
    { "path": "local/guard-config.json", "note": "shared optional guard extras" },
    { "path": "local/council/config.json", "note": "shared disabledProjects" },
    { "path": "local/seats.codex.json", "note": "native=codex exec (host model) + external roster {Opus,GLM,Gemini,Grok}" },
    { "path": "local/isolated-codex-home/", "note": "empty neutral CODEX_HOME for the codex external seat's recursion isolation (when the host is NOT Codex)" }
  ]
}

#!/bin/sh
# Execute a Leo's Agents Python entry point with this clone's private runtime.
# No activation is needed; this deliberately refuses to fall back to a system Python.
set -eu

SELF=$0
while [ -h "$SELF" ]; do
  BASE=$(CDPATH= cd -- "$(dirname -- "$SELF")" && pwd -P)
  TARGET=$(readlink "$SELF")
  case $TARGET in
    /*) SELF=$TARGET ;;
    *) SELF=$BASE/$TARGET ;;
  esac
done
ROOT=$(CDPATH= cd -- "$(dirname -- "$SELF")/.." && pwd -P)
# Honor LEOS_LOCAL like leos-runtime.py and leos-doctor.py do, so the runtime that setup builds
# and doctor validates is the one this launcher actually runs.
PY="${LEOS_LOCAL:-$ROOT/local}/.venv/bin/python"

if [ ! -x "$PY" ]; then
  echo "Leo's Agents runtime is not installed at ${LEOS_LOCAL:-$ROOT/local}/.venv. Run: python3 $ROOT/bin/leos-runtime.py setup" >&2
  exit 127
fi

exec "$PY" "$@"
